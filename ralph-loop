#!/usr/bin/env bash
set -euo pipefail

POLL_INTERVAL="${RALPH_POLL_INTERVAL:-60}"
LOG_PREFIX="[ralph-loop]"

trap 'log "Shutting down"; exit 0' INT TERM

log() { echo "$LOG_PREFIX $(date '+%Y-%m-%d %H:%M:%S') $*"; }

log "Starting daemon (poll every ${POLL_INTERVAL}s)"

while true; do
  ready_json="$(bd ready --json 2>/dev/null || echo '[]')"
  count="$(echo "$ready_json" | jq 'length')"

  if [ "$count" -eq 0 ]; then
    log "No ready issues, sleeping ${POLL_INTERVAL}s"
    sleep "$POLL_INTERVAL"
    continue
  fi

  log "Found $count ready issue(s)"

  log "Running claude"
  rc=0
  claude -p "$(cat PROMPT.md)" --output-format stream-json --verbose 2>&1 || rc=$?
  log "Claude finished (exit code: $rc)"

  sleep "$POLL_INTERVAL"
done
